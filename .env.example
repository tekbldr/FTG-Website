# ── Supabase ────────────────────────────────────────────────────────────────
# Project URL + anon (public) key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Service-role key — SERVER ONLY. Bypasses RLS. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ── File scanning (choose one path) ──────────────────────────────────────────
# Managed (resumes): Cloudmersive Virus Scan API key. Leave blank to skip in dev.
CLOUDMERSIVE_API_KEY=
# Self-hosted ClamAV endpoint (recommended for confidential pitch docs)
CLAMAV_SCAN_URL=

# ── Email (status notifications) ─────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM="FTG <careers@ftg.vc>"

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Jobs ─────────────────────────────────────────────────────────────────────
# Secret guarding the retention cron (/api/jobs/retention). Vercel Cron sends it
# as `Authorization: Bearer <CRON_SECRET>`. Set a strong random value in prod.
CRON_SECRET=
RETENTION_MONTHS=6
